{
  "name": "@goozyshi/tracker-sdk",
  "version": "1.1.1",
  "description": "Framework-agnostic tracking SDK with Vue directives and React hooks",
  "keywords": [
    "tracker",
    "analytics",
    "vue",
    "react",
    "exposure",
    "click"
  ],
  "license": "MIT",
  "author": "goozyshi",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/lib/index.js",
  "module": "./dist/es/index.js",
  "types": "./dist/es/index.d.ts",
  "unpkg": "./dist/tracker-sdk.min.js",
  "jsdelivr": "./dist/tracker-sdk.min.js",
  "typesVersions": {
    "*": {
      "vue": [
        "./dist/es/vue.d.ts"
      ],
      "vue2": [
        "./dist/es/vue2.d.ts"
      ],
      "react": [
        "./dist/es/react.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/es/vue.d.ts",
        "default": "./dist/es/vue.js"
      },
      "require": {
        "types": "./dist/lib/vue.d.ts",
        "default": "./dist/lib/vue.js"
      }
    },
    "./vue2": {
      "import": {
        "types": "./dist/es/vue2.d.ts",
        "default": "./dist/es/vue2.js"
      },
      "require": {
        "types": "./dist/lib/vue2.d.ts",
        "default": "./dist/lib/vue2.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/es/react.d.ts",
        "default": "./dist/es/react.js"
      },
      "require": {
        "types": "./dist/lib/react.d.ts",
        "default": "./dist/lib/react.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/tracker-sdk.min.js"
  ],
  "scripts": {
    "build": "tsup && node scripts/fix-dts-ext.mjs",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "husky install",
    "changeset": "changeset",
    "version": "changeset version",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome check --write"
    ]
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=2.6.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/react": "^18.2.0",
    "@vue/runtime-core": "^3.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "react": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vue": "^3.4.0"
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=18"
  }
}
