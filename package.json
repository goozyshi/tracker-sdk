{
  "name": "@goozyshi/tracker-sdk",
  "version": "1.0.0",
  "description": "Framework-agnostic tracking SDK with Vue directives and React hooks",
  "keywords": ["tracker", "analytics", "vue", "react", "exposure", "click"],
  "license": "MIT",
  "author": "goozyshi",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./vue2": {
      "types": "./dist/vue2.d.ts",
      "import": "./dist/vue2.js",
      "require": "./dist/vue2.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vue": ">=2.6.0",
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "vue": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vue": "^3.4.0",
    "react": "^18.2.0",
    "@types/react": "^18.2.0"
  }
}
